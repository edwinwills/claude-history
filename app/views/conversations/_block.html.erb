<% case block["type"] %>
<% when "text" %>
  <% if unsupported_placeholder_text?(block["text"]) %>
    <%= unsupported_block_notice %>
  <% else %>
    <%= render_markdown(block["text"].to_s) %>
  <% end %>
<% when "thinking" %>
  <details class="my-2 rounded-md border border-border bg-muted/30 overflow-hidden">
    <summary class="cursor-pointer px-3 py-1.5 text-xs text-muted-foreground select-none">thinking</summary>
    <div class="px-3 py-2 border-t border-border"><pre class="tool-body"><%= block["thinking"].to_s %></pre></div>
  </details>
<% when "tool_use" %>
  <details class="my-2 rounded-md border border-border bg-muted/30 overflow-hidden">
    <summary class="cursor-pointer px-3 py-1.5 text-xs select-none">
      <span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2 py-0.5 text-[10px] font-medium mr-1">tool_use</span>
      <span class="font-mono"><%= block["name"] %></span>
      <span class="text-muted-foreground font-mono ml-2"><%= truncate_plain(block["input"].to_json.to_s, 140) %></span>
    </summary>
    <div class="px-3 py-2 border-t border-border"><pre class="tool-body"><%= JSON.pretty_generate(block["input"] || {}) %></pre></div>
  </details>
<% when "tool_result" %>
  <% inner = block["content"] %>
  <details class="my-2 rounded-md border border-border bg-muted/30 overflow-hidden">
    <summary class="cursor-pointer px-3 py-1.5 text-xs select-none">
      <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2 py-0.5 text-[10px] font-medium mr-1">tool_result</span>
      <span class="text-muted-foreground font-mono"><%= truncate_plain(ClaudeHistory::RecordParser.flatten_content(inner), 140) %></span>
    </summary>
    <div class="px-3 py-2 border-t border-border">
      <% if inner.is_a?(Array) %>
        <% inner.each do |sub| %>
          <%= render "conversations/block", block: sub %>
        <% end %>
      <% else %>
        <pre class="tool-body"><%= inner.to_s %></pre>
      <% end %>
    </div>
  </details>
<% else %>
  <details class="my-2 rounded-md border border-border bg-muted/30 overflow-hidden">
    <summary class="cursor-pointer px-3 py-1.5 text-xs select-none">
      <span class="inline-flex items-center rounded-full bg-muted text-muted-foreground px-2 py-0.5 text-[10px] font-medium mr-1"><%= block["type"] %></span>
    </summary>
    <div class="px-3 py-2 border-t border-border"><pre class="tool-body"><%= JSON.pretty_generate(block) %></pre></div>
  </details>
<% end %>
