<%= turbo_frame_tag "conversation_labels_#{conversation.id}", class: "block" do %>
  <div class="flex flex-wrap items-center gap-2">
    <% conversation.labels.alphabetical.each do |label| %>
      <div class="inline-flex items-center gap-1.5 rounded-full bg-primary text-primary-foreground pl-3 pr-1.5 h-7 text-xs font-medium hover:brightness-90 transition">
        <%= link_to label.name, root_path(label: label.name),
              data: { turbo_frame: "_top" },
              class: "hover:underline" %>
        <%= button_to "✕",
              conversation_label_path(conversation, label),
              method: :delete,
              form: { data: { turbo_frame: "conversation_labels_#{conversation.id}" }, style: "display:contents" },
              class: "opacity-70 hover:opacity-100 text-sm leading-none",
              title: "Remove label" %>
      </div>
    <% end %>

    <%= form_with url: conversation_labels_path(conversation),
          method: :post,
          class: "inline-flex items-center gap-1",
          data: { turbo_frame: "conversation_labels_#{conversation.id}" } do |f| %>
      <%= f.text_field :name,
            placeholder: "Add label…",
            autocomplete: "off",
            list: "labels-datalist",
            class: "flex h-7 rounded-md border border-input bg-background px-2 py-1 text-xs w-40 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" %>
      <%= f.submit "Add",
            class: "inline-flex items-center justify-center rounded-md text-xs font-medium h-7 px-2.5 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors" %>
    <% end %>

    <datalist id="labels-datalist">
      <% Label.alphabetical.pluck(:name).each do |name| %>
        <option value="<%= name %>"></option>
      <% end %>
    </datalist>
  </div>
<% end %>
