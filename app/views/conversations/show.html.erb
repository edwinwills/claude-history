<% content_for :title, "#{@conversation.display_title} — Claude History" %>

<nav class="text-sm text-muted-foreground mb-2">
  <%= link_to "Projects", root_path, class: "hover:text-foreground" %>
  <span class="mx-1">/</span>
  <%= link_to @project.name, project_path(@project), class: "hover:text-foreground" %>
  <span class="mx-1">/</span>
  <span class="text-foreground">Session</span>
</nav>

<%= render "conversations/title", conversation: @conversation, editing: false, variant: :heading %>

<div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground mb-4">
  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide <%= @conversation.desktop? ? 'bg-secondary text-secondary-foreground' : 'bg-primary/10 text-primary' %>"><%= @conversation.source %></span>
  <% if @conversation.code? %>
    <span>Branch: <% if @conversation.git_branch.present? %><code class="font-mono text-foreground"><%= @conversation.git_branch %></code><% else %>—<% end %></span>
  <% end %>
  <span>Started: <%= @conversation.started_at&.strftime("%Y-%m-%d %H:%M") %></span>
  <span>Messages: <%= @conversation.message_count %></span>
  <span>Session: <code class="font-mono text-foreground"><%= @conversation.session_id %></code></span>
  <%= button_to "Move to trash",
        conversation_path(@conversation),
        method: :delete,
        form: { class: "ml-auto", data: { turbo_confirm: "Move this conversation to trash? You can restore it from /trash." } },
        class: "inline-flex items-center justify-center rounded-md text-xs font-medium h-8 px-3 border border-border bg-background hover:bg-destructive hover:text-destructive-foreground hover:border-destructive transition-colors" %>
</div>

<div class="mb-4">
  <%= render "conversations/labels", conversation: @conversation %>
</div>

<% if @conversation.code? %>
  <div class="rounded-lg border border-border bg-card text-card-foreground p-4 mb-6" data-controller="clipboard">
    <div class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Resume in a new terminal</div>
    <div class="flex gap-2 items-center">
      <code class="flex-1 font-mono text-sm bg-muted/40 rounded px-3 py-2 break-all" data-clipboard-target="source"><%= @conversation.resume_command %></code>
      <button type="button"
              class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
              data-action="clipboard#copy" data-clipboard-target="button">Copy</button>
    </div>
  </div>
<% else %>
  <div class="rounded-lg border border-border bg-card text-card-foreground p-4 mb-6">
    <div class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Claude Desktop conversation</div>
    <p class="text-sm">Imported from your claude.ai data export. Open the original at
      <a class="text-primary hover:underline" href="https://claude.ai/chat/<%= @conversation.session_id %>" target="_blank" rel="noopener">
        claude.ai/chat/<%= @conversation.session_id[0, 8] %>…
      </a>
    </p>
  </div>
<% end %>

<div class="flex flex-col gap-3">
  <% @messages.each do |message| %>
    <% is_user = message.role == 'user' %>
    <div class="flex <%= is_user ? 'justify-end' : 'justify-start' %>" id="msg-<%= message.uuid %>">
      <div class="max-w-3xl w-fit">
        <div class="flex items-center gap-2 text-xs text-muted-foreground mb-1 <%= 'justify-end' if is_user %>">
          <span class="uppercase tracking-wide"><%= message.role %></span>
          <span><%= message.timestamp&.strftime("%H:%M:%S") %></span>
        </div>
        <div class="rounded-lg px-4 py-3 border <%= is_user ? 'bg-primary/10 border-primary/30' : 'bg-card border-border' %>">
          <div class="markdown-body text-sm">
            <% message.content_blocks.each do |block| %>
              <%= render "conversations/block", block: block %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
