<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Claude History" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <script>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var theme = ["light", "dark", "system"].indexOf(stored) >= 0 ? stored : "system";
          var isDark = theme === "dark" || (theme === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          if (isDark) document.documentElement.classList.add("dark");
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <header class="sticky top-0 z-30 border-b border-border bg-background/80 backdrop-blur">
      <div class="max-w-6xl mx-auto w-full flex gap-3 px-4 py-3 items-center">
        <%= link_to "Claude History", root_path, class: "text-lg font-semibold tracking-tight hover:text-primary" %>
        <%= form_with url: search_path, method: :get, local: true, class: "flex-1" do |f| %>
          <%= f.search_field :q, value: params[:q], placeholder: "Search all conversations…",
                autocomplete: "off",
                class: "flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" %>
        <% end %>

        <div class="inline-flex items-center rounded-md border border-border bg-background h-9 p-0.5" role="group" aria-label="Theme" data-controller="theme">
          <% [ [ "light", "☀", "Light" ], [ "dark", "☾", "Dark" ], [ "system", "⌂", "System" ] ].each do |value, icon, label| %>
            <button type="button"
                    data-theme-target="option"
                    data-theme-value="<%= value %>"
                    data-action="theme#select"
                    aria-label="<%= label %>"
                    title="<%= label %>"
                    class="inline-flex items-center justify-center h-8 w-8 rounded text-sm hover:bg-accent hover:text-accent-foreground transition-colors text-muted-foreground">
              <%= icon %>
            </button>
          <% end %>
        </div>

        <%= link_to "Labels", labels_path,
              class: "inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 text-muted-foreground hover:bg-accent hover:text-accent-foreground transition-colors" %>
        <%= link_to "Trash", trash_path,
              class: "inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 text-muted-foreground hover:bg-accent hover:text-accent-foreground transition-colors" %>
        <%= button_to "Sync", sync_path, method: :post,
              class: "inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors",
              form_class: "m-0" %>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="max-w-6xl mx-auto w-full px-4 pt-3">
        <div class="rounded-lg border border-border bg-card text-card-foreground px-4 py-3 text-sm">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>

    <main class="max-w-6xl mx-auto w-full px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
