<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Claude History" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <%= link_to "Claude History", root_path, class: "brand" %>
        <%= form_with url: search_path, method: :get, local: true, class: "search-form" do |f| %>
          <%= f.search_field :q, value: params[:q], placeholder: "Search all conversations…", autocomplete: "off" %>
        <% end %>
        <%= button_to "Sync", sync_path, method: :post, class: "sync-btn" %>
      </div>
    </header>
    <% if flash[:notice] %><div class="flash"><div class="wrap"><%= flash[:notice] %></div></div><% end %>
    <main class="wrap">
      <%= yield %>
    </main>
  </body>
</html>
