<% content_for :title, "Projects — Claude History" %>

<div class="flex flex-wrap items-center gap-2 mb-4">
  <span class="text-xs uppercase tracking-wide text-muted-foreground mr-1">Source:</span>
  <% source_preserve = { label: params[:label] }.compact %>
  <% [ [ nil, "All" ], [ "code", "Code" ], [ "desktop", "Desktop" ] ].each do |value, label| %>
    <% active = (@active_source || nil) == value %>
    <%= link_to root_path(source_preserve.merge(source: value)),
          class: "inline-flex items-center rounded-md border px-3 h-8 text-xs font-medium transition-colors #{active ? 'bg-primary text-primary-foreground border-primary' : 'border-border bg-background text-muted-foreground hover:bg-accent hover:text-accent-foreground'}" do %>
      <%= label %>
    <% end %>
  <% end %>
</div>

<% if @all_labels.any? || @active_label %>
  <div class="flex flex-wrap items-center gap-2 mb-4">
    <span class="text-xs uppercase tracking-wide text-muted-foreground mr-1">Label:</span>
    <% label_preserve = { source: @active_source }.compact %>
    <% @all_labels.each do |label| %>
      <% active = @active_label&.id == label.id %>
      <%= link_to root_path(label_preserve.merge(label: (active ? nil : label.name))),
            class: "inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium text-white transition hover:brightness-110 #{active ? 'ring-2 ring-ring ring-offset-2 ring-offset-background' : 'opacity-70 hover:opacity-100'}",
            style: "background-color: #{label.color_with_default}" do %>
        <span><%= label.name %></span>
        <span class="opacity-80"><%= label.conversations.size %></span>
      <% end %>
    <% end %>
    <% if @active_label %>
      <%= link_to "clear ✕", root_path(label_preserve), class: "text-xs text-muted-foreground hover:text-foreground ml-1" %>
    <% end %>
  </div>
<% end %>

<% if @active_label %>
  <div class="flex items-baseline justify-between mb-4">
    <h1 class="text-2xl font-semibold tracking-tight">
      Conversations labeled
      <span class="inline-flex items-center rounded-full text-white px-2.5 py-0.5 text-base font-medium ml-1"
            style="background-color: <%= @active_label.color_with_default %>"><%= @active_label.name %></span>
    </h1>
    <div class="text-sm text-muted-foreground"><%= @labeled_conversations.size %> conversation<%= 's' unless @labeled_conversations.size == 1 %></div>
  </div>

  <% if @labeled_conversations.empty? %>
    <div class="rounded-lg border border-border bg-card text-card-foreground p-8 text-center text-muted-foreground">
      No conversations with this label.
    </div>
  <% else %>
    <div class="rounded-lg border border-border bg-card text-card-foreground overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="border-b border-border text-muted-foreground text-xs uppercase tracking-wide">
            <tr>
              <th class="text-left font-medium px-4 py-3">Title</th>
              <th class="text-left font-medium px-4 py-3">Source</th>
              <th class="text-left font-medium px-4 py-3">Project</th>
              <th class="text-left font-medium px-4 py-3">Labels</th>
              <th class="text-right font-medium px-4 py-3">Messages</th>
              <th class="text-left font-medium px-4 py-3">Last activity</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @labeled_conversations.each do |c| %>
              <tr class="hover:bg-muted/40">
                <td class="px-4 py-2"><%= render "conversations/title", conversation: c, editing: false, variant: :inline %></td>
                <td class="px-4 py-2"><%= source_badge(c.source, size: :sm) %></td>
                <td class="px-4 py-2"><%= link_to c.project.name, project_path(c.project), class: "text-primary hover:underline" %></td>
                <td class="px-4 py-2">
                  <div class="flex flex-wrap gap-1">
                    <% c.labels.alphabetical.each do |l| %>
                      <%= link_to l.name, root_path(label: l.name),
                            class: "inline-flex items-center rounded-full px-2 py-0.5 text-xs text-white transition hover:brightness-110 #{'ring-2 ring-ring ring-offset-1 ring-offset-background' if l.id == @active_label.id}",
                            style: "background-color: #{l.color_with_default}" %>
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-2 text-right"><span class="text-muted-foreground"><%= c.message_count %></span></td>
                <td class="px-4 py-2 text-muted-foreground" title="<%= c.last_activity_at %>"><%= relative_time(c.last_activity_at) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="flex items-baseline justify-between mb-4">
    <h1 class="text-2xl font-semibold tracking-tight">Projects</h1>
    <div class="flex gap-4 text-sm text-muted-foreground">
      <div><span class="font-medium text-foreground"><%= @projects.size %></span> projects</div>
      <div><span class="font-medium text-foreground"><%= @total_conversations %></span> conversations</div>
    </div>
  </div>

  <% if @projects.empty? %>
    <div class="rounded-lg border border-border bg-card text-card-foreground p-8 text-center">
      <p class="text-muted-foreground">No conversations indexed yet.</p>
      <p class="text-sm text-muted-foreground mt-1">Click <span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2.5 py-0.5 text-xs">Sync</span> to scan <code class="font-mono">~/.claude/projects</code>.</p>
    </div>
  <% else %>
    <div class="rounded-lg border border-border bg-card text-card-foreground overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="border-b border-border text-muted-foreground text-xs uppercase tracking-wide">
            <tr>
              <th class="text-left font-medium px-4 py-3">Project</th>
              <th class="text-left font-medium px-4 py-3">Source</th>
              <th class="text-left font-medium px-4 py-3">Path</th>
              <th class="text-right font-medium px-4 py-3">Sessions</th>
              <th class="text-left font-medium px-4 py-3">Last activity</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @projects.each do |project| %>
              <tr class="hover:bg-muted/40">
                <td class="px-4 py-2"><%= link_to project.name, project_path(project), class: "font-medium text-primary hover:underline" %></td>
                <td class="px-4 py-2"><%= source_badge(project.source, size: :sm) %></td>
                <td class="px-4 py-2">
                  <% if project.desktop? %>
                    <span class="text-xs text-muted-foreground italic">(from claude.ai export)</span>
                  <% else %>
                    <code class="text-xs text-muted-foreground font-mono"><%= project.path %></code>
                  <% end %>
                </td>
                <td class="px-4 py-2 text-right"><span class="text-muted-foreground"><%= project.conversation_count %></span></td>
                <td class="px-4 py-2 text-muted-foreground" title="<%= project.last_activity_at %>"><%= relative_time(project.last_activity_at) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
<% end %>
