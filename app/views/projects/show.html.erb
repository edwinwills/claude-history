<% content_for :title, "#{@project.name} — Claude History" %>

<div class="text-sm breadcrumbs opacity-70 mb-2">
  <ul>
    <li><%= link_to "Projects", root_path %></li>
    <li><%= @project.name %></li>
  </ul>
</div>

<h1 class="text-2xl font-semibold"><%= @project.name %></h1>
<p class="opacity-70 mb-4"><code class="font-mono text-sm"><%= @project.path %></code></p>

<% if @conversations.empty? %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body items-center">
      <p class="opacity-70">No conversations for this project.</p>
    </div>
  </div>
<% else %>
  <div class="card bg-base-100 shadow-sm">
    <div class="overflow-x-auto">
      <table class="table table-sm">
        <thead>
          <tr>
            <th>Title</th>
            <th class="text-right">Messages</th>
            <th>Branch</th>
            <th>Started</th>
            <th>Last activity</th>
          </tr>
        </thead>
        <tbody>
          <% @conversations.each do |c| %>
            <tr class="hover">
              <td><%= render "conversations/title", conversation: c, editing: false, variant: :inline %></td>
              <td class="text-right"><span class="badge badge-ghost"><%= c.message_count %></span></td>
              <td><% if c.git_branch.present? %><span class="badge badge-outline badge-sm font-mono"><%= c.git_branch %></span><% else %><span class="opacity-40">—</span><% end %></td>
              <td class="opacity-70 text-sm" title="<%= c.started_at %>"><%= relative_time(c.started_at) %></td>
              <td class="opacity-70 text-sm" title="<%= c.last_activity_at %>"><%= relative_time(c.last_activity_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
