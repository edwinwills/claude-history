<% content_for :title, "#{@project.name} — Claude History" %>

<nav class="text-sm text-muted-foreground mb-2">
  <%= link_to "Projects", root_path, class: "hover:text-foreground" %>
  <span class="mx-1">/</span>
  <span class="text-foreground"><%= @project.name %></span>
</nav>

<h1 class="text-2xl font-semibold tracking-tight"><%= @project.name %></h1>
<p class="text-muted-foreground mb-4"><code class="font-mono text-sm"><%= @project.path %></code></p>

<% if @conversations.empty? %>
  <div class="rounded-lg border border-border bg-card text-card-foreground p-8 text-center text-muted-foreground">
    No conversations for this project.
  </div>
<% else %>
  <div class="rounded-lg border border-border bg-card text-card-foreground overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-border text-muted-foreground text-xs uppercase tracking-wide">
          <tr>
            <th class="text-left font-medium px-4 py-3">Title</th>
            <th class="text-right font-medium px-4 py-3">Messages</th>
            <th class="text-left font-medium px-4 py-3">Branch</th>
            <th class="text-left font-medium px-4 py-3">Started</th>
            <th class="text-left font-medium px-4 py-3">Last activity</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @conversations.each do |c| %>
            <tr class="hover:bg-muted/40">
              <td class="px-4 py-2"><%= render "conversations/title", conversation: c, editing: false, variant: :inline %></td>
              <td class="px-4 py-2 text-right"><span class="text-muted-foreground"><%= c.message_count %></span></td>
              <td class="px-4 py-2">
                <% if c.git_branch.present? %>
                  <span class="inline-flex items-center rounded border border-border px-1.5 py-0.5 text-xs font-mono"><%= c.git_branch %></span>
                <% else %>
                  <span class="text-muted-foreground">—</span>
                <% end %>
              </td>
              <td class="px-4 py-2 text-muted-foreground" title="<%= c.started_at %>"><%= relative_time(c.started_at) %></td>
              <td class="px-4 py-2 text-muted-foreground" title="<%= c.last_activity_at %>"><%= relative_time(c.last_activity_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
