<% content_for :title, "Trash — Claude History" %>

<nav class="text-sm text-muted-foreground mb-2">
  <%= link_to "Projects", root_path, class: "hover:text-foreground" %>
  <span class="mx-1">/</span>
  <span class="text-foreground">Trash</span>
</nav>

<div class="flex items-baseline justify-between mb-4">
  <h1 class="text-2xl font-semibold tracking-tight">Trash</h1>
  <div class="text-sm text-muted-foreground"><%= @conversations.size %> conversation<%= 's' unless @conversations.size == 1 %></div>
</div>

<% if @conversations.empty? %>
  <div class="rounded-lg border border-border bg-card text-card-foreground p-8 text-center text-muted-foreground">
    Trash is empty.
  </div>
<% else %>
  <div class="rounded-lg border border-border bg-card text-card-foreground overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-border text-muted-foreground text-xs uppercase tracking-wide">
          <tr>
            <th class="text-left font-medium px-4 py-3">Title</th>
            <th class="text-left font-medium px-4 py-3">Source</th>
            <th class="text-left font-medium px-4 py-3">Project</th>
            <th class="text-right font-medium px-4 py-3">Messages</th>
            <th class="text-left font-medium px-4 py-3">Deleted</th>
            <th class="text-right font-medium px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @conversations.each do |c| %>
            <tr class="hover:bg-muted/40">
              <td class="px-4 py-2 text-muted-foreground"><%= c.display_title %></td>
              <td class="px-4 py-2"><%= source_badge(c.source, size: :sm) %></td>
              <td class="px-4 py-2"><%= link_to c.project.name, project_path(c.project), class: "text-primary hover:underline" %></td>
              <td class="px-4 py-2 text-right text-muted-foreground"><%= c.message_count %></td>
              <td class="px-4 py-2 text-muted-foreground" title="<%= c.deleted_at %>"><%= relative_time(c.deleted_at) %></td>
              <td class="px-4 py-2 text-right">
                <%= button_to "Restore",
                      restore_conversation_path(c),
                      method: :patch,
                      class: "inline-flex items-center justify-center rounded-md text-xs font-medium h-8 px-3 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
